# Copy this file to .env and fill in your own values.
# Do not commit .env. It contains API keys, private dataset IDs, and local ports.

# === Docker images and ports ===
PYTHON_IMAGE=python:3.13-slim
NODE_IMAGE=node:22-alpine
FRONTEND_PORT=3001
BACKEND_PORT=8001
DIFY_PROXY_PORT=3002
BACKEND_URL=http://backend:8000
NEXT_PUBLIC_BACKEND_URL=http://localhost:8001
BACKEND_HEALTHCHECK_URL=http://localhost:8000/api/system/health
CORS_ORIGINS=["http://localhost:3001","http://127.0.0.1:3001"]

# Dify is optional. Leave DIFY_API_BASE and DIFY_BASE_URL empty for the default
# local deployment. To enable it, deploy Dify separately, set this to the Dify
# Compose network, fill the Dify variables below, and start AI4Sec with:
#   docker compose --profile dify up -d --build
DIFY_DOCKER_NETWORK=docker_default

# === LLM provider (OpenAI-compatible) ===
LLM_BASEURL=https://api.openai.com/v1
LLM_APIKEY=
THINKING_MODELNAME=
EMBED_MODELNAME=
RERANK_MODELNAME=

# === MinerU PDF parsing ===
MINERU_TOKEN=
MINERU_API_BASE=https://mineru.net/api/v4
MINERU_MODEL_VERSION=vlm
MINERU_POLL_INTERVAL_SECONDS=6
MINERU_PARSE_TIMEOUT_SECONDS=1800
MINERU_BATCH_TIMEOUT_SECONDS=7200

# === Publication rank / web fallback ===
EASYSCHOLAR_SECRET_KEY=
EASYSCHOLAR_API_URL=https://www.easyscholar.cc/open/getPublicationRank
TAVILY_KEY=
TAVILY_SEARCH_URL=https://api.tavily.com/search

# === Research Sphere full-text fetching (optional) ===
UNPAYWALL_EMAIL=
UNPAYWALL_API_URL=https://api.unpaywall.org/v2/{doi}
CORE_API_KEY=
CORE_SEARCH_API_URL=https://api.core.ac.uk/v3/search/works/
ELSEVIER_API_KEY=
ELSEVIER_INSTTOKEN=
ELSEVIER_ARTICLE_API_URL=https://api.elsevier.com/content/article/doi/{doi}
WILEY_TDM_TOKEN=
WILEY_TDM_API_URL=https://api.wiley.com/onlinelibrary/tdm/v1/articles/{doi}

# === Academic metadata APIs ===
OPENALEX_API_BASE=https://api.openalex.org
SEMANTIC_SCHOLAR_API_BASE=https://api.semanticscholar.org
CROSSREF_API_BASE=https://api.crossref.org
PAPERSEARCH_SEMANTICSCHOLAR_API_KEY=
PAPERSEARCH_SEMANTICSCHOLAR_API_BASE=https://api.semanticscholar.org
PAPERSEARCH_OPENALEX_API_BASE=https://api.openalex.org
PAPERSEARCH_CROSSREF_API_BASE=https://api.crossref.org
PAPERSEARCH_IEEE_API_KEY=
PAPERSEARCH_IEEE_API_URL=https://ieeexploreapi.ieee.org/api/v1/search/articles
PAPERSEARCH_PER_PLATFORM_LIMIT=10
PAPERSEARCH_FINAL_LIMIT=10
PAPERSEARCH_FINAL_LIMIT_MAX=50

# === Research Sphere limits ===
SPHERE_RADIUS=1
SPHERE_CANDIDATE_CAP=200
SPHERE_LAYER1_CAP=40
SPHERE_PDF_PARSE_CAP=0

# === Dify knowledge base via local proxy (optional) ===
# Backend talks to the local proxy. Empty disables corpus RAG and Dify sync.
DIFY_API_BASE=
DIFY_DEFAULT_DATASET_ID=
DIFY_ANALYSIS_DATASET_ID=
DIFY_SEARCH_METHOD=keyword_search
DIFY_TIMEOUT_SECONDS=90
DIFY_SPHERE_TOP_K=10

# Proxy talks to your Dify instance and holds the real Dify API key.
# When dify-proxy joins Dify's Compose network, DIFY_BASE_URL is usually http://nginx.
DIFY_BASE_URL=
DIFY_DATASET_API_KEY=

# === DeepLX translation (optional) ===
DEEPLX_API_BASE=
DEEPLX_API_KEY=
DEEPLX_TIMEOUT_SECONDS=30

# === Daily arXiv recommendations ===
DAILY_RECOMMENDATION_ENABLED=true
DAILY_RECOMMENDATION_LOOKBACK_DAYS=3
DAILY_RECOMMENDATION_MAX_RESULTS_PER_TOPIC=80
DAILY_RECOMMENDATION_MIN_SCORE=0.68
DAILY_RECOMMENDATION_LLM_REVIEW_ENABLED=false
DAILY_RECOMMENDATION_LLM_REVIEW_LIMIT=20
DAILY_RECOMMENDATION_TRANSLATE_ENABLED=true
DAILY_RECOMMENDATION_TRANSLATE_TARGET=zh
DAILY_RECOMMENDATION_ARXIV_API_URL=https://export.arxiv.org/api/query
DAILY_RECOMMENDATION_SOURCE_DATASET_ID=
DAILY_RECOMMENDATION_ANALYSIS_DATASET_ID=
DAILY_RECOMMENDATION_DEFAULT_SOURCE_SPACE=daily_source
DAILY_RECOMMENDATION_DEFAULT_ANALYSIS_SPACE=daily_analysis
DAILY_RECOMMENDATION_AUTO_REFRESH_ENABLED=true
DAILY_RECOMMENDATION_AUTO_REFRESH_HOUR=6
DAILY_RECOMMENDATION_AUTO_REFRESH_MINUTE=0
DAILY_RECOMMENDATION_AUTO_REFRESH_TIMEZONE=Asia/Shanghai

# === Knowledge-card generation ===
AUTO_KNOWLEDGE_CARDS_ENABLED=true
AUTO_KNOWLEDGE_CARD_MAX_PER_RUN=12
AUTO_KNOWLEDGE_CARD_MODEL=
AUTO_KNOWLEDGE_CARD_PROMPT_VERSION=kg_card_v1

# === Large papers and supplementary material ===
DOCUMENT_PARTITION_ENABLED=true
SUPPLEMENTARY_INDEX_ENABLED=true
SUPPLEMENTARY_MAX_INDEX_CHARS=18000
SUPPLEMENTARY_MAX_EXPAND_CHARS=24000
SUPPLEMENTARY_DETECTION_MIN_CONFIDENCE=0.65
LENS_MAIN_BODY_ONLY=true

# === Security / operations ===
# Set before exposing the backend beyond localhost.
ADMIN_API_TOKEN=
ENABLE_DOCS=true
