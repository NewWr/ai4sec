AI4SEC_DATA_DIR=../docker-data
AI4SEC_APP_DB=../docker-data/app.db
DIFY_SYNC_STATE_DB=./state/dify_syncs.db

# If this container joins the Dify compose network, nginx is reachable by service name.
DIFY_BASE_URL=http://nginx:80
DIFY_DATASET_API_KEY=replace-with-dify-dataset-api-key
DIFY_DATASET_ID=replace-with-dify-dataset-id

# Alternative: use an existing proxy instead of direct Dify API.
# DIFY_PROXY_BASE_URL=http://ai4sec-dify-proxy:3002

DIFY_INDEXING_TECHNIQUE=economy
DIFY_PROCESS_RULE_MODE=automatic
DIFY_SYNC_INTERVAL_SECONDS=30
DIFY_SYNC_MAX_ATTEMPTS=5
DIFY_SYNC_MAX_TEXT_CHARS=0
